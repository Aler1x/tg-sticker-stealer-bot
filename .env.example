# Telegram Bot Token from @BotFather
TOKEN=your_bot_token_here

# PostgreSQL Database Connection String
# Railway provides this automatically when you connect a PostgreSQL database
DATABASE_URL=postgresql://username:password@host:port/database?sslmode=require

# Webhook Configuration
# Use webhooks when PUBLIC_URL is set, otherwise use long polling
# Railway automatically provides PORT env var
RAILWAY_PUBLIC_DOMAIN=https://your-app.railway.app
RAILWAY_PORT=8443

# Admin Configuration
# Comma-separated list of Telegram user IDs with admin privileges
# Get your user ID by messaging @userinfobot on Telegram
ADMIN_IDS=123456789,987654321

